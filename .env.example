# Copy this file to ".env" and paste in your own keys.
# Never share your real .env or commit it — it's your passwords.

# From @BotFather in Telegram (/newbot gives you this)
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenFromBotFather

# Your own Telegram chat id (the README shows a 10-second way to get it)
TELEGRAM_CHAT_ID=123456789

# Free from console.groq.com -> API Keys
GROQ_API_KEY=gsk_ExampleKeyFromConsoleGroqCom

# From Supabase -> Project Settings -> API Keys
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=sb_secret_ExampleSecretKeyNotThePublishableOne
